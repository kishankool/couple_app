# ── Firebase Configuration ──
# Get these from: Firebase Console → Project Settings → General → Your apps
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── App Passphrase Hash ──
# Generate this by running: npm run setup-pass
# NEVER put your actual passphrase here — only the hash!
VITE_APP_PASSHASH=your_sha256_hash_here

# ── Cloudinary Configuration ──
# Get these from: Cloudinary Dashboard → Settings → Upload
# Create an unsigned upload preset in Settings → Upload → Upload presets
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Cloudinary Configuration ──
# Get these from: Cloudinary Dashboard → Settings → Upload
# Create an unsigned upload preset in Settings → Upload → Upload presets
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
