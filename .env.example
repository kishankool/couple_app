# ── Firebase (Firestore only — no Storage needed) ──────────────────────────────
# Get from: Firebase Console → Project Settings → Your Apps → SDK setup & config
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# ── Cloudinary (FREE photo hosting — no payment needed) ────────────────────────
# Get from: cloudinary.com → Dashboard → Cloud name
# Upload preset: Settings → Upload → Upload Presets → Add preset → Signing mode: Unsigned
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_name_here
