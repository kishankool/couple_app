rules_version = '2';

// Kishan & Aditi Couple App — Firestore Security Rules
// ─────────────────────────────────────────────────────
//
// Auth model: Firebase Anonymous Auth
//   - Owners call signInAnonymously() after entering the correct passphrase.
//   - Firebase issues a real cryptographic token the server verifies.
//   - Visitors never sign in, so they only reach collections where read: if true.
//   - No browser-side hack (sessionStorage etc.) can fake request.auth.
//
// PUBLIC collections (anyone can read, owners can write):
//   - memories       → Polaroid memories / scrapbook
//   - events         → Countdowns / upcoming events
//
// PRIVATE collections (read + write require Firebase Anonymous Auth):
//   - Everything else

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: caller has a valid Firebase session ──
    function isOwner() {
      return request.auth != null;
    }

    // ── PUBLIC: anyone can read, owners can write ──
    match /memories/{docId} {
      allow read:  if true;
      allow write: if isOwner();
    }

    match /events/{docId} {
      allow read:  if true;
      allow write: if isOwner();
    }

    // ── PRIVATE: owners only ──
    match /notes/{docId}             { allow read, write: if isOwner(); }
    match /todos/{docId}             { allow read, write: if isOwner(); }
    match /updates_photos/{docId}    { allow read, write: if isOwner(); }
    match /updates_locations/{docId} { allow read, write: if isOwner(); }
    match /moods/{docId}             { allow read, write: if isOwner(); }
    match /date_ideas/{docId}        { allow read, write: if isOwner(); }
    match /couple_answers/{docId}    { allow read, write: if isOwner(); }
    match /good_morning/{docId}      { allow read, write: if isOwner(); }
    match /miss_you/{docId}          { allow read, write: if isOwner(); }
    match /hugs_kisses/{docId}       { allow read, write: if isOwner(); }
    match /photos/{docId}            { allow read, write: if isOwner(); }
    match /locations/{docId}         { allow read, write: if isOwner(); }
    match /love_reasons/{docId}      { allow read, write: if isOwner(); }
    match /wishlist/{docId}          { allow read, write: if isOwner(); }
    match /push_subs/{docId}         { allow read, write: if isOwner(); }
    match /cal_events/{docId}        { allow read, write: if isOwner(); }
    match /time_capsules/{docId}     { allow read, write: if isOwner(); }
    match /love_chat/{docId}         { allow read, write: if isOwner(); }
    match /expenses/{docId}           { allow read, write: if isOwner(); }
    match /settlements/{docId}        { allow read, write: if isOwner(); }
  }
}
